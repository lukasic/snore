FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG GIT_COMMIT_SHORT_SHA
ARG GIT_COMMIT_TIME
ARG GIT_COMMIT_INFO
ARG GIT_COMMIT_BRANCH
ARG GIT_COMMIT_COUNT
ARG GITLAB_PIPELINE_ID

ENV VITE_GIT_COMMIT_HASH=$GIT_COMMIT_SHORT_SHA
ENV VITE_GIT_COMMIT_TIME=$GIT_COMMIT_TIME
ENV VITE_GIT_COMMIT_INFO=$GIT_COMMIT_INFO
ENV VITE_GIT_COMMIT_BRANCH=$GIT_COMMIT_BRANCH
ENV VITE_GIT_COMMIT_COUNT=$GIT_COMMIT_COUNT
ENV VITE_PIPELINE_ID=$GITLAB_PIPELINE_ID

RUN npm run build

FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf.template /etc/nginx/templates/default.conf.template

EXPOSE 80
